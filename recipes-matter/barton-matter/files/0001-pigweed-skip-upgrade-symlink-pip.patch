From b5d269962c7aad02b775e078a56e91acf117cbfc Mon Sep 17 00:00:00 2001
From: Christian Leithner <christian_leithner@comcast.com>
Date: Wed, 21 Jan 2026 16:41:37 +0000
Subject: [PATCH] Yocto: Skip pip upgrade and use native sysroot pip via
 symlink

In Yocto builds, skip the pip upgrade step and instead symlink the pip
module from python3-pip-native in the native sysroot. This allows the
venv to use the pip already provided by Yocto's build system.

Generated by Copilot AI
Signed-off-by: Christian Leithner <christian_leithner@comcast.com>

---
 .../pw_env_setup/virtualenv_setup/install.py  | 60 ++++++++++++++-----
 1 file changed, 46 insertions(+), 14 deletions(-)

diff --git a/third_party/pigweed/repo/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py b/third_party/pigweed/repo/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py
index 9343c06..2c1ad98 100644
--- a/third_party/pigweed/repo/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py
+++ b/third_party/pigweed/repo/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py
@@ -330,20 +330,52 @@ def install(  # pylint: disable=too-many-arguments,too-many-locals,too-many-stat
             '--constraint={}'.format(constraint) for constraint in constraints
         )
 
-    pip_install(
-        '--log',
-        os.path.join(venv_path, 'pip-upgrade.log'),
-        '--upgrade',
-        'pip',
-        'setuptools',
-        'toml',  # Needed for pyproject.toml package installs.
-        # Include wheel so pip installs can be done without build
-        # isolation.
-        'wheel',
-        'pip-tools',
-        constraint_args,
-    )
-
+    # Detect Yocto environment and skip pip upgrade to use native sysroot pip
+    yocto_env = (
+        os.environ.get('YOCTO_BUILD') is not None or
+        os.environ.get('OECORE_NATIVE_SYSROOT') is not None or
+        'yocto' in str(python).lower() or
+        'poky' in str(python).lower()
+       )
+    if not yocto_env:
+        # Skip pip upgrade in Yocto to preserve manually extracted pip/setuptools
+        pip_install(
+            '--log',
+            os.path.join(venv_path, 'pip-upgrade.log'),
+            '--upgrade',
+            'pip',
+            'setuptools',
+            'toml',  # Needed for pyproject.toml package installs.
+            # Include wheel so pip installs can be done without build
+            # isolation.
+            'wheel',
+            'pip-tools',
+            constraint_args,
+        )
+    else:
+        print('YOCTO BUILD: Skipping pip upgrade, using native sysroot pip')
+
+        # Ensure pip is available in venv by symlinking from host python3-pip-native
+        venv_site_packages = os.path.join(venv_path, 'lib', 'python{}.{}'.format(*sys.version_info[:2]), 'site-packages')
+        os.makedirs(venv_site_packages, exist_ok=True)
+
+        # Find pip in host Python installation
+        host_pip_path = None
+        for path in sys.path:
+            if 'site-packages' in path and os.path.exists(os.path.join(path, 'pip')):
+                host_pip_path = os.path.join(path, 'pip')
+                break
+
+        if host_pip_path:
+            venv_pip_path = os.path.join(venv_site_packages, 'pip')
+            if not os.path.exists(venv_pip_path):
+                try:
+                    os.symlink(host_pip_path, venv_pip_path)
+                    print(f'YOCTO BUILD: Symlinked pip from {host_pip_path} to {venv_pip_path}')
+                except Exception as e:
+                    print(f'YOCTO BUILD: Failed to symlink pip: {e}')
+        else:
+            print('YOCTO BUILD: Warning - pip not found in host Python paths')
     # TODO(tonymd): Remove this when projects have defined requirements.
     if (not requirements) and constraints:
         requirements = constraints
