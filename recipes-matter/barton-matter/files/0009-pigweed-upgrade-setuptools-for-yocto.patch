From b80c4fcebfefc2aca29f56aafe5e149bc20b8738 Mon Sep 17 00:00:00 2001
From: Christian Leithner <christian_leithner@comcast.com>
Date: Thu, 22 Jan 2026 18:06:36 +0000
Subject: [PATCH] Yocto: Upgrade setuptools in venv to support editable_wheel

Yocto Kirkstone provides setuptools 59.5.0, but chip-mobly requires
setuptools>=64.0.0 for editable_wheel build backend support.

Force upgrade setuptools to >=68.0.0 in the virtualenv using pip install
with --target to ensure it installs to venv site-packages, not system paths.
Clear PYTHONPATH during upgrade to prevent system interference.

Generated by Copilot AI
Signed-off-by: Christian Leithner <christian_leithner@comcast.com>

---
 .../pw_env_setup/virtualenv_setup/install.py  | 20 +++++++++++++++++++
 1 file changed, 20 insertions(+)

diff --git a/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py b/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py
index e69392a..9582505 100644
--- a/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py
+++ b/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py
@@ -376,6 +376,26 @@ def install(  # pylint: disable=too-many-arguments,too-many-locals,too-many-stat
                     print(f'YOCTO BUILD: Failed to symlink pip: {e}')
         else:
             print('YOCTO BUILD: Warning - pip not found in host Python paths')
+
+        # Upgrade setuptools in venv to override old system version
+        # (Yocto sysroot has setuptools < 64.0.0, need >= 64.0.0 for editable_wheel)
+        # Use --target to force install to venv site-packages (not system location)
+        print('YOCTO BUILD: Upgrading setuptools in venv to override system version')
+        import subprocess
+        venv_python = os.path.join(venv_path, 'bin', 'python3')
+        venv_site_packages = os.path.join(venv_path, 'lib', f'python{sys.version_info.major}.{sys.version_info.minor}', 'site-packages')
+        subprocess.run(
+            [venv_python, '-m', 'pip', 'install',
+             '--log', os.path.join(venv_path, 'pip-setuptools-upgrade.log'),
+             '--upgrade', '--ignore-installed',
+             '--target', venv_site_packages,  # Force to venv site-packages
+             'setuptools>=68.0.0'],
+            env={
+                **os.environ,
+                'PYTHONPATH': '',  # Clear to prevent system interference
+            },
+            check=True
+        )
     # TODO(tonymd): Remove this when projects have defined requirements.
     if (not requirements) and constraints:
         requirements = constraints
