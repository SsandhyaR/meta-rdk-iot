From 8c571430451e567a60ed614683a9148b55d89335 Mon Sep 17 00:00:00 2001
From: Christian Leithner <christian_leithner@comcast.com>
Date: Wed, 21 Jan 2026 17:00:51 +0000
Subject: [PATCH] pigweed: Enable system-site-packages for Yocto sysroot access

Enable system_site_packages=True in all Pigweed virtual environment
creation to allow access to Yocto's python3-native packages installed
in the sysroot (jinja2, more-itertools, etc).

Changes:
- create_gn_venv.py: Add system_site_packages=True to both venv.create() calls
- env_setup.py: Change _virtualenv_system_packages defaults to True
- install.py: Change system_packages parameter default to True

Generated by Copilot AI
---
 pw_build/py/pw_build/create_gn_venv.py                   | 4 ++--
 pw_env_setup/py/pw_env_setup/env_setup.py                | 4 ++--
 pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py | 2 +-
 3 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/pw_build/py/pw_build/create_gn_venv.py b/pw_build/py/pw_build/create_gn_venv.py
index 4ef27ef..cedb9f6 100644
--- a/pw_build/py/pw_build/create_gn_venv.py
+++ b/pw_build/py/pw_build/create_gn_venv.py
@@ -85,7 +85,7 @@ def main(
     if yocto_env:
         print("YOCTO BUILD: Creating GN venv with native sysroot pip via symlink")
         # Create venv without pip first in Yocto
-        venv.create(destination_dir, symlinks=True, with_pip=False)
+        venv.create(destination_dir, symlinks=True, with_pip=False, system_site_packages=True)
 
         # Symlink pip from sysroot to the new venv
         venv_site_packages = destination_dir / 'lib' / f'python{sys.version_info.major}.{sys.version_info.minor}' / 'site-packages'
@@ -108,7 +108,7 @@ def main(
         else:
             print("YOCTO BUILD: Warning - pip not found in host Python paths")
     else:
-        venv.create(destination_dir, symlinks=True, with_pip=True)
+        venv.create(destination_dir, symlinks=True, with_pip=True, system_site_packages=True)
 
     # Write out the depfile, making sure the Python path is
     # relative to the outdir so that this doesn't add user-specific
diff --git a/pw_env_setup/py/pw_env_setup/env_setup.py b/pw_env_setup/py/pw_env_setup/env_setup.py
index f92ee07..c493e45 100755
--- a/pw_env_setup/py/pw_env_setup/env_setup.py
+++ b/pw_env_setup/py/pw_env_setup/env_setup.py
@@ -223,7 +223,7 @@ class EnvSetup:
         self._use_pinned_pip_packages = use_pinned_pip_packages
         self._optional_submodules = []
         self._required_submodules = []
-        self._virtualenv_system_packages = False
+        self._virtualenv_system_packages = True
         self._pw_packages = []
         self._root_variable = None
 
@@ -371,7 +371,7 @@ class EnvSetup:
         )
 
         self._virtualenv_system_packages = virtualenv.pop(
-            'system_packages', False
+            'system_packages', True
         )
 
         for req_txt in _assert_sequence(virtualenv.pop('requirements', ())):
diff --git a/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py b/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py
index 2c1ad98..e69392a 100644
--- a/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py
+++ b/pw_env_setup/py/pw_env_setup/virtualenv_setup/install.py
@@ -201,7 +201,7 @@ def install(  # pylint: disable=too-many-arguments,too-many-locals,too-many-stat
     gn_out_dir=None,
     python=sys.executable,
     env=None,
-    system_packages=False,
+    system_packages=True,
     use_pinned_pip_packages=True,
 ):
     """Creates a venv and installs all packages in this Git repo."""
