From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Christian Leithner <christian_leithner@comcast.com>
Date: Mon, 20 Jan 2026 19:05:00 +0000
Subject: [PATCH] bootstrap: Handle tput errors gracefully

When TERM is not set or set to a terminal type that doesn't support
color commands (like 'dumb'), tput will fail with a non-zero exit code.
Since these tput calls are near the end of bootstrap.sh, the script
returns that error code when sourced, causing do_configure to fail.

Fix by redirecting tput stderr and using '|| true' to ensure the
commands always succeed.

Generated by Copilot AI

Upstream-Status: Pending
Signed-off-by: Christian Leithner <christian_leithner@comcast.com>

---
 scripts/setup/bootstrap.sh | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/scripts/setup/bootstrap.sh b/scripts/setup/bootstrap.sh
index 63b1b8848ba..8d4f67c100644
--- a/scripts/setup/bootstrap.sh
+++ b/scripts/setup/bootstrap.sh
@@ -223,7 +223,7 @@ pw_cleanup
 
 if _submodules_need_updating; then
   # yellow output
-  if which tput >/dev/null; then tput setaf 3; fi
+  if which tput >/dev/null 2>&1; then tput setaf 3 2>/dev/null || true; fi
 
   echo "Some submodules seem out of date."
   echo "For a clean checkout, consider running:"
@@ -232,7 +232,7 @@ if _submodules_need_updating; then
   echo "   git submodule update -f --init --recursive"
 
   # reset output
-  if which tput >/dev/null; then tput sgr0; fi
+  if which tput >/dev/null 2>&1; then tput sgr0 2>/dev/null || true; fi
 fi
 
 unset _ACTION_TAKEN
