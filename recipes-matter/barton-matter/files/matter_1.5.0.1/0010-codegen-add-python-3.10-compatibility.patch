From 9fb936ab52743e3dad6b336cfd7d0834afcdf5da Mon Sep 17 00:00:00 2001
From: Christian Leithner <christian_leithner@comcast.com>
Date: Wed, 28 Jan 2026 16:06:35 +0000
Subject: [PATCH] codegen: Add Python 3.10 compatibility for log levels

logging.getLevelNamesMapping() was added in Python 3.11.
Add fallback for Python 3.10 to use manual log level mapping.

Upstream-Status: Pending
---
 scripts/codegen.py | 16 +++++++++++++++-
 1 file changed, 15 insertions(+), 1 deletion(-)

diff --git a/scripts/codegen.py b/scripts/codegen.py
index 13632cefc0a..683fb438bcc 100755
--- a/scripts/codegen.py
+++ b/scripts/codegen.py
@@ -61,7 +61,21 @@ class ListGeneratedFilesStorage(GeneratorStorage):

 # Supported log levels, mapping string values required for argument
 # parsing into logging constants
-__LOG_LEVELS__ = logging.getLevelNamesMapping()
+# Note: getLevelNamesMapping() was added in Python 3.11
+if sys.version_info >= (3, 11):
+    __LOG_LEVELS__ = logging.getLevelNamesMapping()
+else:
+    # Fallback for Python 3.10 and earlier
+    __LOG_LEVELS__ = {
+        'CRITICAL': logging.CRITICAL,
+        'FATAL': logging.FATAL,
+        'ERROR': logging.ERROR,
+        'WARN': logging.WARNING,
+        'WARNING': logging.WARNING,
+        'INFO': logging.INFO,
+        'DEBUG': logging.DEBUG,
+        'NOTSET': logging.NOTSET,
+    }


 @click.command()
--
