From 17cdc179e2e682491bf2dd1b0b1e77e9d0ea884b Mon Sep 17 00:00:00 2001
From: Christian Leithner <christian_leithner@comcast.com>
Date: Wed, 21 Jan 2026 16:50:38 +0000
Subject: [PATCH] Yocto: Fix GN venv creation to use native sysroot pip via
 symlink

In Yocto builds, create GN venv without pip and symlink the pip module
from python3-pip-native in the native sysroot, consistent with the main
pigweed venv setup approach.

Generated by Copilot AI
Signed-off-by: Christian Leithner <christian_leithner@comcast.com>

---
 pw_build/py/pw_build/create_gn_venv.py | 37 +++++++++++++++++++++++++-
 1 file changed, 36 insertions(+), 1 deletion(-)

diff --git a/third_party/pigweed/repo/pw_build/py/pw_build/create_gn_venv.py b/third_party/pigweed/repo/pw_build/py/pw_build/create_gn_venv.py
index f8ac2fc..4ef27ef 100644
--- a/third_party/pigweed/repo/pw_build/py/pw_build/create_gn_venv.py
+++ b/third_party/pigweed/repo/pw_build/py/pw_build/create_gn_venv.py
@@ -73,7 +73,42 @@ def main(
     # Create the virtualenv.
     if destination_dir.exists():
         _rm_dir(destination_dir)
-    venv.create(destination_dir, symlinks=True, with_pip=True)
+
+    # Detect Yocto environment and use native sysroot pip via symlink
+    yocto_env = (
+        os.environ.get('YOCTO_BUILD') is not None or
+        os.environ.get('OECORE_NATIVE_SYSROOT') is not None or
+        'yocto' in str(sys.executable).lower() or
+        'poky' in str(sys.executable).lower()
+    )
+
+    if yocto_env:
+        print("YOCTO BUILD: Creating GN venv with native sysroot pip via symlink")
+        # Create venv without pip first in Yocto
+        venv.create(destination_dir, symlinks=True, with_pip=False)
+
+        # Symlink pip from sysroot to the new venv
+        venv_site_packages = destination_dir / 'lib' / f'python{sys.version_info.major}.{sys.version_info.minor}' / 'site-packages'
+        venv_site_packages.mkdir(parents=True, exist_ok=True)
+
+        # Find pip in host Python installation
+        host_pip_path = None
+        for path_str in sys.path:
+            path = pathlib.Path(path_str)
+            pip_path = path / 'pip'
+            if 'site-packages' in path_str and pip_path.exists():
+                host_pip_path = pip_path
+                break
+
+        if host_pip_path:
+            dest_pip = venv_site_packages / 'pip'
+            if not dest_pip.exists():
+                dest_pip.symlink_to(host_pip_path)
+                print(f"YOCTO BUILD: Symlinked pip from {host_pip_path} to {dest_pip}")
+        else:
+            print("YOCTO BUILD: Warning - pip not found in host Python paths")
+    else:
+        venv.create(destination_dir, symlinks=True, with_pip=True)
 
     # Write out the depfile, making sure the Python path is
     # relative to the outdir so that this doesn't add user-specific
-- 
