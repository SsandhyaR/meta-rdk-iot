From ab8b1c9f904b89aa715ea83a8ea134430d06b3cc Mon Sep 17 00:00:00 2001
From: Christian Leithner <christian_leithner@comcast.com>
Date: Thu, 22 Jan 2026 18:13:54 +0000
Subject: [PATCH] Yocto: Fix bash completion for POSIX shell compatibility

Process substitution <(...) is a bash-specific feature that is disabled
in POSIX mode, causing syntax errors when sourcing bash-completion.sh
during bootstrap.

Replace readarray with process substitution:
  readarray -t COMPREPLY < <(compgen ...)

With POSIX-compatible command substitution:
  COMPREPLY=($(compgen ...))

This allows bash-completion.sh to work when sourced from sh/POSIX shells.

Generated by Copilot AI
Signed-off-by: Christian Leithner <christian_leithner@comcast.com>

---
 scripts/helpers/bash-completion.sh | 32 +++++++++++++++---------------
 1 file changed, 16 insertions(+), 16 deletions(-)

diff --git a/scripts/helpers/bash-completion.sh b/scripts/helpers/bash-completion.sh
index 63b1b8848ba..fd59a265ce9 100644
--- a/scripts/helpers/bash-completion.sh
+++ b/scripts/helpers/bash-completion.sh
@@ -49,7 +49,7 @@ _chip_build_example() {
     if [[ -z "$command" ]]; then
         case "$prev" in
             --target)
-                readarray -t COMPREPLY < <(compgen -W "$("$1" targets --format=completion "$cur")" -- "$cur")
+COMPREPLY=($(compgen -W "$("$1" targets --format=completion "$cur")" -- "$cur"))
                 compopt -o nospace
                 return
                 ;;
@@ -64,7 +64,7 @@ _chip_build_example() {
         esac
         case "$cur" in
             -*)
-                readarray -t COMPREPLY < <(compgen -W "$(_parse_help "$1")" -- "$cur")
+COMPREPLY=($(compgen -W "$(_parse_help "$1")" -- "$cur"))
                 return
                 ;;
         esac
@@ -72,7 +72,7 @@ _chip_build_example() {
 
     # Complete the command name.
     if [[ "$command_comp_cword" -eq "$COMP_CWORD" ]]; then
-        readarray -t COMPREPLY < <(compgen -W "$commands" -- "$cur")
+COMPREPLY=($(compgen -W "$commands" -- "$cur"))
         return
     fi
 
@@ -82,7 +82,7 @@ _chip_build_example() {
     # Command-specific completion.
     case "$prev" in
         --format)
-            readarray -t COMPREPLY < <(compgen -W "summary expanded json" -- "$cur")
+COMPREPLY=($(compgen -W "summary expanded json" -- "$cur"))
             return
             ;;
         --copy-artifacts-to | --create-archives)
@@ -92,7 +92,7 @@ _chip_build_example() {
     esac
     case "$cur" in
         -*)
-            readarray -t COMPREPLY < <(compgen -W "$("$1" "$command" --help | _parse_help -)" -- "$cur")
+COMPREPLY=($(compgen -W "$("$1" "$command" --help | _parse_help -)" -- "$cur"))
             ;;
     esac
 
@@ -117,18 +117,18 @@ _chip_app() {
 
     case "$prev" in
         --ble-controller)
-            readarray -t words < <(ls -I '*:*' /sys/class/bluetooth)
+words=($(ls -I '*:*' /sys/class/bluetooth))
             # Get the list of Bluetooth devices without the 'hci' prefix.
-            readarray -t COMPREPLY < <(compgen -W "${words[*]#hci}" -- "$cur")
+COMPREPLY=($(compgen -W "${words[*]#hci}" -- "$cur"))
             return
             ;;
         --custom-flow)
-            readarray -t COMPREPLY < <(compgen -W "0 1 2" -- "$cur")
+COMPREPLY=($(compgen -W "0 1 2" -- "$cur"))
             return
             ;;
         --capabilities)
             # The capabilities option is a bit-field with 3 bits currently defined.
-            readarray -t COMPREPLY < <(compgen -W "001 010 011 100 101 111" -- "$cur")
+COMPREPLY=($(compgen -W "001 010 011 100 101 111" -- "$cur"))
             return
             ;;
         --KVS)
@@ -144,11 +144,11 @@ _chip_app() {
             return
             ;;
         --trace_log | --trace_decode)
-            readarray -t COMPREPLY < <(compgen -W "0 1" -- "$cur")
+COMPREPLY=($(compgen -W "0 1" -- "$cur"))
             return
             ;;
         --trace-to)
-            readarray -t COMPREPLY < <(compgen -W "json perfetto" -- "$cur")
+COMPREPLY=($(compgen -W "json perfetto" -- "$cur"))
             compopt -o nospace
             return
             ;;
@@ -156,7 +156,7 @@ _chip_app() {
 
     case "$cur" in
         -*)
-            readarray -t COMPREPLY < <(compgen -W "$(_parse_help "$1")" -- "$cur")
+COMPREPLY=($(compgen -W "$(_parse_help "$1")" -- "$cur"))
             ;;
     esac
 
@@ -172,11 +172,11 @@ _chip_tool() {
 
     case "$prev" in
         --commissioner-name)
-            readarray -t COMPREPLY < <(compgen -W "alpha beta gamma 4 5 6 7 8 9" -- "$cur")
+COMPREPLY=($(compgen -W "alpha beta gamma 4 5 6 7 8 9" -- "$cur"))
             return
             ;;
         --only-allow-trusted-cd-keys)
-            readarray -t COMPREPLY < <(compgen -W "0 1" -- "$cur")
+COMPREPLY=($(compgen -W "0 1" -- "$cur"))
             return
             ;;
         --paa-trust-store-path | --cd-trust-store-path | --dac-revocation-set-path)
@@ -188,7 +188,7 @@ _chip_tool() {
             return
             ;;
         --trace-to)
-            readarray -t COMPREPLY < <(compgen -W "json perfetto" -- "$cur")
+COMPREPLY=($(compgen -W "json perfetto" -- "$cur"))
             compopt -o nospace
             return
             ;;
@@ -202,7 +202,7 @@ _chip_tool() {
             words=$(_chip_tool_get_commands "${args[@]}")
             ;;
     esac
-    readarray -t COMPREPLY < <(compgen -W "$words" -- "$cur")
+COMPREPLY=($(compgen -W "$words" -- "$cur"))
 
 }
 
